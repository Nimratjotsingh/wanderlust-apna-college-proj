<% layout('layouts/boilerplate.ejs') %>
<script>
     const coordinates = <%=JSON.stringify(data.geometry.coordinates)%>;
</script>
<body>
    <% if (data) {%>
        
        <img src=<%=data.image.url%>>
        <p><i>owned by <%=data.owner.username%></i></p> 
        <h3><%=data.title%></h3>
        <p><%=data.description%></p>
        <p>₹<%=data.price.toLocaleString('en-IN')%></p>
        <p><%=data.location%></p>
        <p><%=data.country%></p>
        
        <% if (show){%>
            <a href="/edit/<%=data._id%>"><button>Edit This</button></a>
            <form method="POST" action="/listing/<%=data._id%>?_method=DELETE">
                <button>Delete</button>
           </form>
        <%}%>
        
    
    <hr>
    <div>
      
    </div>
    <% if(userId !== null){%>

    
    <div>
        <h4>Leave a review</h4>
        <form action="/listing/<%=data._id%>/review" method="POST">
            <!-- <div>
                
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div> -->
            <div>
                <label for="rating" class="form-label"> Rating </label>
            <fieldset class="starability-slot">
                
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            </div>
            <div>
                <label for="comment"> Comment </label>
                <textarea name="review[comment]" id="comment" class="form-control" required></textarea>
                <div class="invalid-feedback">Please submit some comments for review.</div>
            </div>
            <br>
            <button class="btn btn-outline-dark">Submit</button>
        </form>
    <%}%>
        <br>
        <div>
            <h4>Reviews</h4>
            <ul>
                <% for(review of data.reviews){%>
                    <li>
                        <div class="card" style="width: 18rem;">
                            <div class="card-body">
                                <h5 class="card-title">@<%= review.author?.username || "Anonymous" %></h5>
                                
                                <p class="starability-result" data-rating=<%=review.rating%> ></p>
                                <p class="card-text"><%=review.comment%></p>
                                <a href="#" class="card-link">Card link</a>
                                <form action="/listing/<%=data._id%>/review/<%=review._id%>?_method=DELETE" method="POST">
                                    <button class="btn btn-danger">Delete</button>
                                </form>
                            </div>
                        </div>
                    </li>
                <%}%>
            </ul>

        </div>
        <div class="col-8 offset-3">
            <h3>Where you will be</h3>
            <div id="map" style="width: 100%; height: 300px;"></div>
        </div>
    </div>
    <%}%>
   
</body>
<script src="/js/map.js"></script>